{
  "height": 30,
  "spacing": 4,
  "modules-left": [
    "custom/terminal",
    "custom/fileexplorer",
    "custom/browser",
    // "custom/steam",
    "custom/discord",
    "hyprland/window"
  ],
  "modules-center": [
    "hyprland/workspaces",
    "privacy"
  ],
  "modules-right": [
    "tray",
    "wireplumber",
    "backlight",
    "network",
    "bluetooth",
    "cpu",
    "memory",
    "battery",
    "clock",
    "custom/power"
  ],
  "custom/terminal": {
    "format": "<span size=\"xx-large\">ï’‰</span>", // î¯ٹ
    "tooltip-format": "Terminal Emulator",
    "on-click": "~/.local/bin/apps/terminal.sh"
  },
  "custom/fileexplorer": {
    "format": "<span size=\"xx-large\">َ°‰–</span>",
    "tooltip-format": "File Explorer",
    "on-click": "~/.local/bin/apps/fileexplorer.sh"
  },
  "custom/browser": {
    "format": "<span size=\"xx-large\">َ°–ں</span>",
    "tooltip-format": "Web Browser",
    "on-click": "~/.local/bin/apps/browser.sh"
  },
  "custom/steam": {
    "format": "<span size=\"xx-large\">ï†¶</span>", // î´©
    "tooltip-format": "Steam",
    "on-click": "~/.local/bin/apps/steam.sh"
  },
  "custom/discord": {
    "format": "<span size=\"xx-large\">ï‡؟</span>",
    "tooltip-format": "Discord",
    "on-click": "~/.local/bin/apps/discord.sh"
  },
  "hyprland/window": {
    "format": "{title}",
    "seperate-outputs": true,
    "rewrite": {
      "\\s*(.*)\\s+": "$1", // Remove trailing whitespace
      "\\s*": "${USER}@${HOST}", // Set title when no windows are present
      ".* â€” LibreWolf": "LibreWolf"
    }
  },
  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "active": "ï„‘",
      "empty": "ï’ھ",
      "default": "ï’ھ",
      "urgent": "ï†’",
      "special": "َ° ±"
    },
    "persistent-workspaces": {
      "*": 5
    },
    "on-scroll-up": "hyprctl dispatch workspace +1 > /dev/null",
    "on-scroll-down": "hyprctl dispatch workspace -1 > /dev/null"
  },
  "privacy": {
    "icon-size": 14,
    "modules": [
      {
        "type": "screenshare",
        "tooltip": true,
        "tooltip-icon-size": 24
      },
      {
        "type": "audio-in",
        "tooltip": true,
        "tooltip-icon-size": 24
      }
    ]
  },
  "tray": {
    "spacing": 6
  },
  "wireplumber": {
    "format": "<span size=\"xx-large\">{icon}</span> <span rise=\"3pt\">{volume}</span>",
    "format-muted": "<span size=\"xx-large\">î»¨</span>",
    "format-icons": [ "î»¨", "ï€§", "ï€¨" ],
    "on-click": "pamixer -t",
    "on-click-right": "qpwgraph",
    "on-scroll-up": "~/.local/bin/volume/volume_up.sh",
    "on-scroll-down": "~/.local/bin/volume/volume_down.sh"
  },
  "backlight": {
    "device": "amdgpu_bl0",
    "format": "<span size=\"xx-large\">{icon}</span> <span rise=\"2.5pt\">{percent}</span>",
    "format-icons": [ "îڈ•", "îڈ”", "îڈ“", "îڈ’", "îڈ‘", "îڈگ", "îڈڈ", "îڈچ", "îڈŒ", "îڈٹ",  "îڈ‰", "îڈˆ", "îژ›" ],
    "on-scroll-up": "~/.local/bin/brightness/brightness_up.sh",
    "on-scroll-down": "~/.local/bin/brightness/brightness_down.sh"
  },
  "network": {
    "interval": 1,
    "format": "{ifname}",
    "format-wifi": "<span size=\"xx-large\">{icon}</span>",
    "format-ethernet": "<span size=\"xx-large\">î¼‰</span>",
    "format-disconnected": "<span size=\"xx-large\">َ°–ھ</span>",
    "format-icons": [ "َ°¤¯", "َ°¤ں", "َ°¤¢", "َ°¤¥", "َ°¤¨" ],
    "on-click": "~/.local/bin/apps/terminal.sh nmtui"
  },
  "bluetooth": {
    "format-on": "<span size=\"large\">َ°‚¯</span>",
    "format-off": "<span size=\"x-large\">َ°‚²</span>",
    "format-disabled": "<span size=\"x-large\">َ°‚²</span>",
    "format-connected": "<span size=\"x-large\">َ°‚±</span> {device_alias}",
    "on-click-right": "~/.local/bin/bt/bt_gui.sh",
    "on-click": "~/.local/bin/bt/bt_toggle.sh"
  },
  "cpu": {
    "interval": 1,
    "format": "<span size=\"x-large\">ï’¼</span> <span rise=\"2pt\">{usage}</span>",
    "format-alt": "<span size=\"x-large\">ï’¼</span> <span rise=\"2pt\">{avg_frequency}GHz</span>",
    "on-click-right": "~/.local/bin/apps/sysmon.sh"
  },
  "memory": {
    "interval": 1,
    "format": "<span size=\"xx-large\">î؟…</span> <span rise=\"3pt\">{percentage}</span>",
    "format-alt": "<span size=\"xx-large\">î؟…</span> <span rise=\"2.5pt\">{used:0.1f}G/{total:0.1f}G</span>",
    "on-click-right": "~/.local/bin/apps/sysmon.sh"
  },
  "battery": {
    "interval": 1,
    "format": "<span size=\"large\">{icon}</span> {capacity}",
    "format-charging": "<span size=\"large\">َ°‚„</span> {capacity}",
    "format-icons": [ "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹" ],
    "on-click": "~/.local/bin/apps/batmon.sh"
  },
  "clock": {
    "interval": 1,
    "format": "<span size=\"xx-large\">ï€—</span> <span rise=\"3pt\">{:%H:%M:%S}</span>",
    "format-alt": "<span size=\"xx-large\">ï€—</span> <span rise=\"3pt\">{:%F}</span>"
  },
  "custom/power": {
    "format": "<span size=\"xx-large\">ï€‘</span>",
    "tooltip-format": "Power Options",
    "on-click": "~/.local/bin/power/menu.sh",
    "on-double-click": "~/.local/bin/power/shutdown.sh",
    "on-triple-click": "~/.local/bin/power/reboot.sh"
  }
}
