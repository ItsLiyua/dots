{
  "height": 30,
  "spacing": 4,
  "modules-left": [
    // "custom/quicklinks",
    "hyprland/window"
  ],
  "modules-center": [
    "hyprland/workspaces"
  ],
  "modules-right": [
    "tray",
    "wireplumber",
    "backlight",
    "network",
    "bluetooth",
    "cpu",
    "memory",
    "battery",
    "clock"
  ],
  "hyprland/window": {
    "format": "{title}",
    "seperate-outputs": true,
    "rewrite": {
      "(.*)[ \t\r\n]+": "$1"
    }
  },
  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "active": "п„‘",
      "empty": "п’Є",
      "default": "п’Є",
      "urgent": "п†’",
      "special": "у° ±"
    },
    "persistent-workspaces": {
      "*": 5
    },
    "on-scroll-up": "hyprctl dispatch workspace +1 > /dev/null",
    "on-scroll-down": "hyprctl dispatch workspace -1 > /dev/null"
  },
  "wireplumber": {
    "format": "<span size=\"xx-large\">{icon}</span> <span rise=\"2pt\">{volume}</span>",
    "format-muted": "<span size=\"xx-large\">о»Ё</span>",
    "format-icons": [ "о»Ё", "пЂ§", "пЂЁ" ],
    "on-click": "qpwgraph",
    "on-scroll-up": "~/.local/scripts/volume_up.sh",
    "on-scroll-down": "~/.local/scripts/volume_down.sh"
  },
  "backlight": {
    "device": "amdgpu_bl0",
    "format": "<span size=\"xx-large\">{icon}</span> <span rise=\"2pt\">{percent}</span>",
    "format-icons": [ "оЏ•", "оЏ”", "оЏ“", "оЏ’", "оЏ‘", "оЏђ", "оЏЏ", "оЏЌ", "оЏЊ", "оЏЉ",  "оЏ‰", "оЏ€", "оЋ›" ],
    "on-scroll-up": "brightnessctl -q set +1%",
    "on-scroll-down": "brightnessctl -q set 1%-"
  },
  "network": {
    "interval": 1,
    "format": "{ifname}",
    "format-wifi": "<span size=\"xx-large\">{icon}</span> <span rise=\"2pt\">{essid}</span>",
    "format-ethernet": "<span size=\"xx-large\">ој‰</span> <span rise=\"2pt\">{ifname}</span>",
    "format-disconnected": "<span size=\"xx-large\">у°–Є</span>",
    "format-icons": [ "у°¤Ї", "у°¤џ", "у°¤ў", "у°¤Ґ", "у°¤Ё" ],
    "on-click": "kitty nmtui"
  },
  "bluetooth": {
    "format-on": "<span size=\"large\">у°‚Ї</span>",
    "format-off": "<span size=\"large\">у°‚І</span>",
    "format-disabled": "<span size=\"large\">у°‚І</span>",
    "format-connected": "<span size=\"x-large\">у°‚±</span> {device_alias}",
    "on-click-right": "kitty bluetuith",
    "on-click": "~/.local/scripts/bt_toggle.sh"
  },
  "cpu": {
    "interval": 1,
    "format": "<span size=\"x-large\">п’ј</span> <span rise=\"0.5pt\">{usage}</span>",
    "format-alt": "<span size=\"x-large\">п’ј</span> <span rise=\"0.5pt\">{avg_frequency}GHz</span>",
    "on-click-right": "kitty btop"
  },
  "memory": {
    "interval": 1,
    "format": "<span size=\"xx-large\">ої…</span> <span rise=\"2pt\">{percentage}</span>",
    "format-alt": "<span size=\"xx-large\">ої…</span> <span rise=\"2pt\">{used}GiB/{total}GiB</span>",
    "on-click-right": "kitty btop"
  },
  "battery": {
    "interval": 1,
    "format": "<span size=\"large\">{icon}</span> {capacity}",
    "format-charging": "<span size=\"large\">у°‚„</span> {capacity}",
    "format-icons": [ "у°Ѓє", "у°Ѓ»", "у°Ѓј", "у°ЃЅ", "у°Ѓѕ", "у°Ѓї", "у°‚Ђ", "у°‚Ѓ", "у°‚‚", "у°Ѓ№" ],
    "on-click": "kitty battop"
  },
  "clock": {
    "interval": 1,
    "format": "<span size=\"xx-large\">пЂ—</span> <span rise=\"2pt\">{:%H:%M:%S}</span>",
    "format-alt": "<span size=\"xx-large\">пЂ—</span> <span rise=\"2pt\">{:%F}</span>",
  }
}
