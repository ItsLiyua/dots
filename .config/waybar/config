{
  "height": 30,
  "spacing": 4,
  "modules-left": [
    // "custom/quicklinks",
    "hyprland/window"
  ],
  "modules-center": [
    "hyprland/workspaces"
  ],
  "modules-right": [
    "tray",
    "wireplumber",
    "backlight",
    "network",
    "bluetooth",
    "cpu",
    "memory",
    "battery",
    "clock"
  ],
  "hyprland/window": {
    "format": "{title}",
    "seperate-outputs": true,
    "rewrite": {
      "(.*)[ \t\r\n]+": "$1"
    }
  },
  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "active": "",
      "empty": "",
      "default": "",
      "urgent": "",
      "special": "󰠱"
    },
    "persistent-workspaces": {
      "*": 5
    },
    "on-scroll-up": "hyprctl dispatch workspace +1 > /dev/null",
    "on-scroll-down": "hyprctl dispatch workspace -1 > /dev/null"
  },
  "wireplumber": {
    "format": "{icon} <span rise=\"2pt\">{volume}</span>",
    "format-muted": "<span size=\"xx-large\"></span>",
    "format-icons": [
      "<span size=\"xx-large\"></span>",
      "<span size=\"xx-large\"></span>",
      "<span size=\"xx-large\"></span>",
    ],
    "on-click": "qpwgraph",
    "on-scroll-up": "~/.local/scripts/volume_up.sh",
    "on-scroll-down": "~/.local/scripts/volume_down.sh"
  }
}
