{
  "height": 30,
  "spacing": 4,
  "modules-left": [
    "custom/terminal",
    "custom/fileexplorer",
    "custom/browser",
    // "custom/steam",
    "custom/discord",
    "hyprland/window",
  ],
  "modules-center": [
    "hyprland/workspaces",
    "privacy"
  ],
  "modules-right": [
    "tray",
    "wireplumber",
    "backlight",
    "network",
    "bluetooth",
    "cpu",
    "memory",
    "battery",
    "clock",
    "custom/power",
  ],
  "custom/terminal": {
    "format": "<span size=\"xx-large\"></span>", // 
    "tooltip-format": "Terminal Emulator",
    "on-click": "kitty"
  },
  "custom/fileexplorer": {
    "format": "<span size=\"xx-large\">󰉖</span>",
    "tooltip-format": "File Explorer",
    "on-click": "dolphin"
  },
  "custom/browser": {
    "format": "<span size=\"xx-large\">󰖟</span>",
    "tooltip-format": "Web Browser",
    "on-click": "librewolf"
  },
  "custom/steam": {
    "format": "<span size=\"xx-large\"></span>", // 
    "tooltip-format": "Steam",
    "on-click": "steam-runtime"
  },
  "custom/discord": {
    "format": "<span size=\"xx-large\"></span>",
    "tooltip-format": "Discord",
    "on-click": "vesktop"
  },
  "hyprland/window": {
    "format": "{title}",
    "seperate-outputs": true,
    "rewrite": {
      "\\s*(.*)\\s+": "$1", // Remove trailing whitespace
      "\\s*": "liyua@endurance", // Set title when no windows are present
      ".* — LibreWolf": "LibreWolf",
    }
  },
  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "active": "",
      "empty": "",
      "default": "",
      "urgent": "",
      "special": "󰠱"
    },
    "persistent-workspaces": {
      "*": 5
    },
    "on-scroll-up": "hyprctl dispatch workspace +1 > /dev/null",
    "on-scroll-down": "hyprctl dispatch workspace -1 > /dev/null"
  },
  "privacy": {
    "icon-size": 14,
    "modules": [
      {
        "type": "screenshare",
        "tooltip": true,
        "tooltip-icon-size": 24
      },
      {
        "type": "audio-in",
        "tooltip": true,
        "tooltip-icon-size": 24
      }
    ]
  },
  "tray": {
    "spacing": 6
  },
  "wireplumber": {
    "format": "<span size=\"xx-large\">{icon}</span> <span rise=\"3pt\">{volume}</span>",
    "format-muted": "<span size=\"xx-large\"></span>",
    "format-icons": [ "", "", "" ],
    "on-click": "pamixer -t",
    "on-click-right": "qpwgraph",
    "on-scroll-up": "~/.local/scripts/volume_up.sh",
    "on-scroll-down": "~/.local/scripts/volume_down.sh"
  },
  "backlight": {
    "device": "amdgpu_bl0",
    "format": "<span size=\"xx-large\">{icon}</span> <span rise=\"2.5pt\">{percent}</span>",
    "format-icons": [ "", "", "", "", "", "", "", "", "", "",  "", "", "" ],
    "on-scroll-up": "brightnessctl -q set +1%",
    "on-scroll-down": "brightnessctl -q set 1%-"
  },
  "network": {
    "interval": 1,
    "format": "{ifname}",
    // "format-wifi": "<span size=\"xx-large\">{icon}</span> <span rise=\"2.5pt\">{essid}</span>",
    "format-wifi": "<span size=\"xx-large\">{icon}</span>",
    "format-ethernet": "<span size=\"xx-large\"></span> <span rise=\"2.5pt\">{ifname}</span>",
    "format-disconnected": "<span size=\"xx-large\">󰖪</span>",
    "format-icons": [ "󰤯", "󰤟", "󰤢", "󰤥", "󰤨" ],
    "on-click": "kitty nmtui"
  },
  "bluetooth": {
    "format-on": "<span size=\"large\">󰂯</span>",
    "format-off": "<span size=\"x-large\">󰂲</span>",
    "format-disabled": "<span size=\"x-large\">󰂲</span>",
    "format-connected": "<span size=\"x-large\">󰂱</span> {device_alias}",
    "on-click-right": "kitty bluetuith",
    "on-click": "~/.local/scripts/bt_toggle.sh"
  },
  "cpu": {
    "interval": 1,
    "format": "<span size=\"x-large\"></span> <span rise=\"2pt\">{usage}</span>",
    "format-alt": "<span size=\"x-large\"></span> <span rise=\"2pt\">{avg_frequency}GHz</span>",
    "on-click-right": "kitty btop"
  },
  "memory": {
    "interval": 1,
    "format": "<span size=\"xx-large\"></span> <span rise=\"3pt\">{percentage}</span>",
    "format-alt": "<span size=\"xx-large\"></span> <span rise=\"2.5pt\">{used:0.1f}G/{total:0.1f}G</span>",
    "on-click-right": "kitty btop"
  },
  "battery": {
    "interval": 1,
    "format": "<span size=\"large\">{icon}</span> {capacity}",
    "format-charging": "<span size=\"large\">󰂄</span> {capacity}",
    "format-icons": [ "󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹" ],
    "on-click": "kitty battop"
  },
  "clock": {
    "interval": 1,
    "format": "<span size=\"xx-large\"></span> <span rise=\"3pt\">{:%H:%M:%S}</span>",
    "format-alt": "<span size=\"xx-large\"></span> <span rise=\"3pt\">{:%F}</span>",
  },
  "custom/power": {
    "format": "<span size=\"xx-large\"></span>",
    "tooltip-format": "Power Options",
    "on-click": "wlogout",
    "on-double-click": "doas shutdown now",
    "on-triple-click": "doas reboot now"
  }
}
